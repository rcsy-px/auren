# Public image and version used by docker-compose.yml.
AUREN_IMAGE=ghcr.io/rcsy-px/auren
AUREN_VERSION=latest

# Host port exposed by Docker.
AUREN_PORT=8080

# Optional global WeatherAPI.com key. Can also be configured in the UI.
WEATHERAPI_KEY=

# Version check source. Set AUREN_UPDATE_CHECK=false to disable outbound update checks.
AUREN_RELEASE_REPO=rcsy-px/auren
AUREN_UPDATE_CHECK=true
